// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  phone         String?   @unique
  password      String?
  role          UserRole  @default(USER)
  isOnline      Boolean   @default(false)
  isActive      Boolean   @default(false)
  status        String    @default("PENDING")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  orders        Order[]
  driverProfile DriverProfile?
  mitraProfile  MitraProfile?
  notifications Notification[]
  pushTokens    PushToken[]

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum UserRole {
  USER
  DRIVER
  MITRA
  ADMIN
}

model DriverProfile {
  id              String    @id @default(cuid())
  userId          String    @unique
  licenseNumber   String    @unique
  licenseExpiry   DateTime?
  vehicleType     VehicleType
  vehiclePlate    String    @unique
  currentLocation Json?
  isAvailable     Boolean   @default(true)
  rating          Float     @default(0)
  totalTrips      Int       @default(0)
  balance         Float     @default(0)
  
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders          Order[]
  driverLocations DriverLocation[]

  @@map("driver_profiles")
}

enum VehicleType {
  MOTORCYCLE
  CAR
}

model MitraProfile {
  id              String    @id @default(cuid())
  userId          String    @unique
  shopName        String
  shopAddress     String
  shopPhone       String
  businessLicense String?
  isVerified      Boolean   @default(false)
  description     String?
  logo            String?
  rating          Float     @default(0)
  balance         Float     @default(0)
  
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  products        Product[]
  orders          Order[]

  @@map("mitra_profiles")
}

model Product {
  id          String   @id @default(cuid())
  mitraId     String
  name        String
  description String?
  price       Float
  category    String
  image       String?
  available   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  mitra       MitraProfile @relation(fields: [mitraId], references: [id], onDelete: Cascade)
  orderItems  OrderItem[]

  @@map("products")
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  userId          String
  driverId        String?
  mitraId         String?
  type            OrderType
  status          OrderStatus @default(PENDING)
  pickupAddress   Json
  deliveryAddress Json?
  items           OrderItem[]
  totalPrice      Float
  deliveryFee     Float
  driverFee       Float?
  mitraRevenue    Float?
  paymentMethod   String
  paymentStatus   PaymentStatus @default(PENDING)
  estimatedTime   Int?
  actualTime      Int?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  user            User         @relation(fields: [userId], references: [id])
  driver          DriverProfile? @relation(fields: [driverId], references: [id])
  mitra           MitraProfile?  @relation(fields: [mitraId], references: [id])
  notifications   Notification[]

  @@map("orders")
}

enum OrderType {
  OJEK
  FOOD
}

enum OrderStatus {
  PENDING
  ACCEPTED
  PREPARING
  READY
  PICKING_UP
  ON_THE_WAY
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float
  
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model DriverLocation {
  id        String   @id @default(cuid())
  driverId  String
  latitude  Float
  longitude Float
  timestamp DateTime @default(now())
  
  driver    DriverProfile @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@map("driver_locations")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  title     String
  message   String
  type      NotificationType
  data      Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  order     Order?           @relation(fields: [orderId], references: [id])
  orderId   String?

  @@map("notifications")
}

enum NotificationType {
  NEW_ORDER
  ORDER_STATUS
  PAYMENT
  SYSTEM
}

model PushToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("push_tokens")
}
